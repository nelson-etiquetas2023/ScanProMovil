<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScanProMovil.Views.ProductsPage"
             Title="Productos">

    <ScrollView>
        <VerticalStackLayout Margin="0,0,0,20" Spacing="10" >
            <Label 
        Text="Opciones de Productos:"
        VerticalOptions="Start"
        FontAttributes="Bold"
        HorizontalOptions="Center" />
            <!--opcion Gestión productos-->
            <HorizontalStackLayout Background="#f0f0f0" HorizontalOptions="Fill">
                
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="LoadProducts" />
                </HorizontalStackLayout.GestureRecognizers>
                
                <Image Source="package_delivery_logistics_50px.png" />
                <VerticalStackLayout HeightRequest="100" Padding="10,25,0,0">
                    <Label Text="Gestión de productos" FontAttributes="Bold" />
                    <Label Text="muestra los productos almacenados" FontSize="10" />
                </VerticalStackLayout>
                <Image Source="chevron_right_50px.png" />
            </HorizontalStackLayout>

            <!--sincronizar productos-->
            <HorizontalStackLayout Background="#f0f0f0" HorizontalOptions="Fill">

                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="SincronizarData" />
                </HorizontalStackLayout.GestureRecognizers>
                
                <Image Source="internet_of_things_50px.png" />
                <VerticalStackLayout HeightRequest="100" Padding="10,25,0,0">
                    <Label Text="Sincronizar Productos" FontAttributes="Bold" />
                    <Label Text="descarga productos desde app web." FontSize="10" />
                </VerticalStackLayout>
                <Image Source="chevron_right_50px.png" />
            </HorizontalStackLayout>

            <!--Codigo de barras-->
            <HorizontalStackLayout Background="#f0f0f0" HorizontalOptions="Fill">

                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="CodeBarModule"/>
                </HorizontalStackLayout.GestureRecognizers>
                
                <Image Source="barcode_50px.png" />
                <VerticalStackLayout HeightRequest="100" Padding="10,25,0,0">
                    <Label Text="Codigos de Barra" FontAttributes="Bold" />
                    <Label Text="Imprime las etiquetas de cod barra." FontSize="10" />
                </VerticalStackLayout>
                <Image Source="chevron_right_50px.png" />
            </HorizontalStackLayout>
            <!--settings-->
            <BoxView HeightRequest="2" BackgroundColor="Gray" HorizontalOptions="Fill"/>
            <Label Text="Setting: " FontSize="16" FontAttributes="Bold"/>

            <Grid Margin="2,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="6*" />
                    <ColumnDefinition Width="4*" />
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Text="Activar Notificaciones" VerticalOptions="Center" />
                <Switch Grid.Column="1"  
                        x:Name="switchActiveNotifications"         
                        HorizontalOptions="End"
                        VerticalOptions="Center"
                        IsToggled="False"
                        ThumbColor="Gray"
                        OnColor="LawnGreen" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>